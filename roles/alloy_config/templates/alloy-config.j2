{# Ambil env dari folder inventory: production / staging / dll #}
{% set env = inventory_dir | basename %}

// --- 0_endpoint.alloy ---
{% include 'fragment/' ~ env ~ '/0_endpoint.alloy' %}

// --- linux.alloy ---
{% include 'fragment/' ~ env ~ '/linux.alloy' %}

// --- docker.alloy ---
{% include 'fragment/' ~ env ~ '/docker.alloy' %}

// --- otel.alloy ---
{% include 'fragment/' ~ env ~ '/otel.alloy' %}

{% if database_server | default('') == 'mysql' %}
// --- mysql.alloy ---
{% include 'fragment/' ~ env ~ '/mysql.alloy' %}
{% elif database_server | default('') == 'postgres' %}
// --- postgres.alloy ---
{% include 'fragment/' ~ env ~ '/postgres.alloy' %}
{% endif %}

{% if 'app_servers' in group_names %}
// --- nginx.alloy ---
{% include 'fragment/' ~ env ~ '/nginx.alloy' %}
{% endif %}